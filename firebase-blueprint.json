{
  "entities": {
    "Exam": {
      "title": "Exam",
      "description": "Exams generated by professors, which can be adapted, recovered or shared.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "grade": { "type": "string" },
        "syllabus": { "type": "string" },
        "difficulty": { "type": "string" },
        "format": { "type": "string" },
        "estimatedTime": { "type": "string" },
        "questions": { "type": "array" },
        "statistics": { "type": "object" },
        "createdAt": { "type": "string" },
        "createdBy": { "type": "string" },
        "developerName": { "type": "string" },
        "originalExamId": { "type": "string" },
        "adaptationType": { "type": "string" },
        "studentPerformanceInfo": { "type": "string" }
      },
      "required": ["title", "subject", "grade", "difficulty", "format", "questions", "createdBy", "createdAt"]
    }
  },
  "firestore": {
    "/exams/{examId}": {
      "schema": "Exam",
      "description": "Store exams created by teachers."
    }
  }
}
